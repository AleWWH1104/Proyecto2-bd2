# ============================================
# CONFIGURACIÓN NEO4J
# ============================================
# Solo descomenta UN bloque (local o Aura)

# --- LOCAL (Docker) ---
# Usado durante desarrollo, antes de subir a Aura
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
NEO4J_DATABASE=neo4j

# --- AURA (producción / colaborativo) ---
# Cuando estén listos para usar Aura, comenten las 4 líneas de arriba
# y descomenten estas. Las credenciales reales las obtienen al crear
# la instancia en https://console.neo4j.io
#
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=tu_password_de_aura
# NEO4J_DATABASE=neo4j

# ============================================
# CONFIGURACIÓN DE LA APP
# ============================================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
